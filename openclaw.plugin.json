{
  "id": "linkmind-context",
  "name": "LinkMind Intelligent Context Compression Engine",
  "version": "1.0.0",
  "kind": "context-engine",
  "description": "Compresses OpenClaw session context with the LinkMind API and registers a custom context engine slot.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiUrl": {
        "type": "string",
        "default": "https://api.linkmind.dev/v1",
        "description": "Base URL of the LinkMind service."
      },
      "logLevel": {
        "type": "string",
        "default": "info",
        "enum": [
          "debug",
          "info",
          "warn",
          "error"
        ],
        "description": "Global log output level."
      }
    }
  }
}
